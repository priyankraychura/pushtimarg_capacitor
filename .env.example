# ==========================================
# Pushtimarg Frontend Environment Variables
# ==========================================
# Copy this file to .env and fill in the values.

# Backend API base URL (include /api/v1 prefix)
VITE_API_BASE_URL=http://localhost:3000/api/v1

# Static content API base URL (optional — defaults to Netlify production URL)
# VITE_CONTENT_API_BASE_URL=https://pushtimarg-web-api.netlify.app
